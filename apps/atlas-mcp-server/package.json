{
  "name": "atlas-mcp-server",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE-SUSTAINABLE-USE IN ROOT",
  "type": "module",
  "bin": {
    "atlas-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "tsx scripts/smoke.ts",
    "test:anchor-json": "tsx scripts/test-anchor-json.ts",
    "test:redact-paths": "tsx scripts/test-redact-paths.ts",
    "test:signer-cache": "tsx scripts/test-signer-binary-cache.ts",
    "test:ulid": "tsx scripts/test-ulid.ts",
    "test": "tsx scripts/test-anchor-json.ts && tsx scripts/test-redact-paths.ts && tsx scripts/test-signer-binary-cache.ts && tsx scripts/test-ulid.ts",
    "lint": "tsc -p tsconfig.lint.json"
  },
  "dependencies": {
    "@atlas/bridge": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
